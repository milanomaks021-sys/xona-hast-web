import Link from 'next/link';
import { useRouter } from 'next/router';

const ITEMS = [
  { href: '/', icon: '🏠', label: 'Главная' },
  { href: '/favorites', icon: '♡', label: 'Избранное' },
  { href: '/add-listing', icon: '➕', label: 'Добавить', main: true },
  { href: '/login', icon: '👤', label: 'Профиль' },
];

export default function BottomNav() {
  const router = useRouter();

  return (
    <nav style={{
      position: 'fixed', bottom: 0, left: 0, right: 0, height: 64,
      background: '#fff', borderTop: '1px solid #EAEDF2',
      display: 'flex', justifyContent: 'space-around', alignItems: 'center',
      zIndex: 100, boxShadow: '0 -4px 16px -8px rgba(15,34,68,0.12)',
      paddingBottom: 'env(safe-area-inset-bottom, 0px)',
    }}>
      {ITEMS.map((item) => {
        const active = router.pathname === item.href;
        if (item.main) {
          return (
            <Link key={item.href} href={item.href} style={{
              textDecoration: 'none', display: 'flex', alignItems: 'center',
              justifyContent: 'center', width: 52, height: 52, borderRadius: '50%',
              background: '#F97316', marginTop: -22,
              boxShadow: '0 8px 16px -4px rgba(249,115,22,0.5)',
              fontSize: 22,
            }}>
              {item.icon}
            </Link>
          );
        }
        return (
          <Link key={item.href} href={item.href} style={{
            textDecoration: 'none', display: 'flex', flexDirection: 'column',
            alignItems: 'center', gap: 2, color: active ? '#F97316' : '#9AA5B8',
            fontSize: 11, fontWeight: active ? 700 : 500,
          }}>
            <span style={{ fontSize: 20 }}>{item.icon}</span>
            {item.label}
          </Link>
        );
      })}
    </nav>
  );
}
