import { useState, useEffect } from 'react';
import Link from 'next/link';
import { getFavorites } from '../lib/favorites';

const API = process.env.NEXT_PUBLIC_API_URL;

export default function Favorites() {
  const [listings, setListings] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const ids = getFavorites();
    if (ids.length === 0) { setLoading(false); return; }
    fetch(`${API}/api/listings?limit=200`)
      .then((r) => r.json())
      .then((res) => {
        if (res.success) setListings((res.data || []).filter((l) => ids.includes(l.id)));
      })
      .catch(() => {})
      .finally(() => setLoading(false));
  }, []);

  return (
    <div style={{ minHeight: '100vh', background: '#F7F8FA', padding: '24px 20px' }}>
      <h1 style={{ fontFamily: 'Georgia, serif', fontSize: 22, color: '#0F2244', margin: '0 0 18px' }}>
        ♡ Избранное
      </h1>

      {loading ? (
        <div style={{ textAlign: 'center', padding: '40px 0', color: '#999' }}>Загрузка...</div>
      ) : listings.length === 0 ? (
        <div style={{ textAlign: 'center', padding: '48px 20px', background: '#fff', borderRadius: 16 }}>
          <div style={{ fontSize: 36, marginBottom: 10 }}>♡</div>
          <div style={{ fontSize: 15, color: '#555' }}>Пока пусто</div>
          <div style={{ fontSize: 13, color: '#999', marginTop: 4 }}>
            Нажимайте на сердечко на объявлениях, чтобы сохранить их здесь
          </div>
        </div>
      ) : (
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(220px, 1fr))', gap: 18 }}>
          {listings.map((l) => (
            <Link key={l.id} href={`/listings/${l.id}`} style={{
              background: '#fff', borderRadius: 16, overflow: 'hidden', display: 'block',
              boxShadow: '0 2px 10px -4px rgba(15,34,68,0.1)',
            }}>
              <div style={{ height: 140, background: '#E8ECF2' }}>
                {l.photos?.[0] && (
                  <img src={l.photos[0]} alt={l.title} style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
                )}
              </div>
              <div style={{ padding: 12 }}>
                <div style={{ fontWeight: 700, fontSize: 15, color: '#0F2244' }}>
                  {l.price_somoni ? `${Number(l.price_somoni).toLocaleString('ru-RU')} смн` : 'Цена не указана'}
                </div>
                <div style={{ fontSize: 13, color: '#444', marginTop: 3 }}>{l.title}</div>
              </div>
            </Link>
          ))}
        </div>
      )}
    </div>
  );
}
